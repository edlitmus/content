<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_008300" version="2">
    <metadata>
      <title>MD7X-00-008300 - MongoDB must use NSA-approved cryptography to protect classified information.</title>
      <description>Checks that MongoDB is configured with TLS in requireTLS mode
      and with FIPS mode enabled. NSA-approved cryptography requires FIPS 140-2/3
      validated modules (FIPSMode) and enforcement of encrypted transport (requireTLS).</description>
      <reference source="STIG" ref_id="MD7X-00-008300" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_008300_oval_mil_disa_stig_mongodb7_tst_tls"
                 comment="net.tls.mode is requireTLS in mongod.conf" />
      <criterion test_ref="mongodb_md7x_00_008300_oval_mil_disa_stig_mongodb7_tst_fips"
                 comment="net.tls.FIPSMode is true in mongod.conf" />
    </criteria>
  </definition>

  <!-- Check net.tls.mode: requireTLS -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_008300_oval_mil_disa_stig_mongodb7_obj_tls"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*mode\s*:\s*requireTLS\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_008300_oval_mil_disa_stig_mongodb7_tst_tls"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="net.tls.mode is requireTLS">
    <ind:object object_ref="mongodb_md7x_00_008300_oval_mil_disa_stig_mongodb7_obj_tls" />
  </ind:textfilecontent54_test>

  <!-- Check net.tls.FIPSMode: true -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_008300_oval_mil_disa_stig_mongodb7_obj_fips"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*FIPSMode\s*:\s*(true|yes)\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_008300_oval_mil_disa_stig_mongodb7_tst_fips"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="net.tls.FIPSMode is true">
    <ind:object object_ref="mongodb_md7x_00_008300_oval_mil_disa_stig_mongodb7_obj_fips" />
  </ind:textfilecontent54_test>

</def-group>
