<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_004300" version="2">
    <metadata>
      <title>MD7X-00-004300 - MongoDB must obscure feedback of authentication information during the authentication process.</title>
      <description>Checks that security.redactClientLogData is true in mongod.conf. When enabled, MongoDB redacts potentially sensitive field values from diagnostic log messages, preventing credential or query content from appearing in logs visible to operators.</description>
      <reference source="STIG" ref_id="MD7X-00-004300" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_004300_oval_mil_disa_stig_mongodb7_tst_21" comment="MD7X-00-004300 pattern 21 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_004300_oval_mil_disa_stig_mongodb7_obj_12" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*redactClientLogData\s*:\s*true\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_004300_oval_mil_disa_stig_mongodb7_tst_21" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-004300 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_004300_oval_mil_disa_stig_mongodb7_obj_12" />
  </ind:textfilecontent54_test>
  </def-group>
