<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_006400" version="2">
    <metadata>
      <title>MD7X-00-006400 - MongoDB must associate security labels with data in storage.</title>
      <description>Checks that WiredTiger encryption at rest is enabled via
      security.enableEncryption: true in mongod.conf. Encryption at rest ensures
      that storage-level data is protected with cryptographic binding equivalent
      to security label enforcement.</description>
      <reference source="STIG" ref_id="MD7X-00-006400" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_006400_encryption_tst"
                 comment="enableEncryption: true configured" />
    </criteria>
  </definition>

  <ind:textfilecontent54_object
      id="mongodb_md7x_00_006400_encryption_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*enableEncryption\s*:\s*(true|yes)\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_006400_encryption_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="WiredTiger encryption at rest enabled in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_006400_encryption_obj" />
  </ind:textfilecontent54_test>

</def-group>
