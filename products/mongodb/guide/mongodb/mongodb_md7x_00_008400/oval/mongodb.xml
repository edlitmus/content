<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_008400" version="2">
    <metadata>
      <title>MD7X-00-008400 - MongoDB must only accept end entity certificates issued by DOD PKI or DOD-approved PKI Certification Authorities.</title>
      <description>Checks that net.tls.CAFile is configured in mongod.conf to reference a Certificate Authority bundle. This ensures MongoDB validates client and server certificates against an authorized CA chain, rejecting certificates issued by unapproved CAs.</description>
      <reference source="STIG" ref_id="MD7X-00-008400" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_008400_oval_mil_disa_stig_mongodb7_tst_24" comment="MD7X-00-008400 pattern 24 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_008400_oval_mil_disa_stig_mongodb7_obj_16" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*CAFile\s*:\s*\S+\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_008400_oval_mil_disa_stig_mongodb7_tst_24" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-008400 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_008400_oval_mil_disa_stig_mongodb7_obj_16" />
  </ind:textfilecontent54_test>
  </def-group>
