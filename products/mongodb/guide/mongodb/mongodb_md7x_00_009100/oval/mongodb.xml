<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_009100" version="2">
    <metadata>
      <title>MD7X-00-009100 - Unnecessary MongoDB software components must be removed or disabled.</title>
      <description>Checks that net.bindIp is explicitly configured in mongod.conf to
      bind MongoDB to specific network interfaces. Restricting network binding reduces
      the set of exposed interfaces, equivalent to removing unused network-exposure
      components.</description>
      <reference source="STIG" ref_id="MD7X-00-009100" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_009100_bindip_tst"
                 comment="net.bindIp is explicitly configured" />
    </criteria>
  </definition>

  <ind:textfilecontent54_object
      id="mongodb_md7x_00_009100_bindip_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*bindIp\s*:\s*\S+\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_009100_bindip_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="net.bindIp is explicitly configured in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_009100_bindip_obj" />
  </ind:textfilecontent54_test>

</def-group>
