<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:unix="http://oval.mitre.org/XMLSchema/oval-definitions-5#unix">

  <definition class="compliance" id="mongodb_md7x_00_002000" version="2">
    <metadata>
      <title>MD7X-00-002000 - The audit information produced by MongoDB must be protected from unauthorized access.</title>
      <description>Checks that the MongoDB audit log directory /var/log/mongodb
      has mode 0750 or more restrictive (rwxr-x---) and is owned by the mongod
      user. This prevents unauthorized users from reading or tampering with audit
      log data produced by MongoDB.</description>
      <reference source="STIG" ref_id="MD7X-00-002000" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_002000_oval_mil_disa_stig_mongodb7_logdir_tst"
                 comment="/var/log/mongodb directory has restricted permissions" />
    </criteria>
  </definition>

  <unix:file_test
      id="mongodb_md7x_00_002000_oval_mil_disa_stig_mongodb7_logdir_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="/var/log/mongodb has mode 0750 (rwxr-x---), owner mongod">
    <unix:object object_ref="mongodb_md7x_00_002000_oval_mil_disa_stig_mongodb7_logdir_obj" />
    <unix:state  state_ref="mongodb_md7x_00_002000_oval_mil_disa_stig_mongodb7_logdir_state" />
  </unix:file_test>

  <unix:file_object
      id="mongodb_md7x_00_002000_oval_mil_disa_stig_mongodb7_logdir_obj"
      version="1">
    <unix:filepath>/var/log/mongodb</unix:filepath>
  </unix:file_object>

  <!-- Mode 0750: owner=rwx, group=rx, other=none -->
  <unix:file_state
      id="mongodb_md7x_00_002000_oval_mil_disa_stig_mongodb7_logdir_state"
      version="1">
    <unix:uread  datatype="boolean">true</unix:uread>
    <unix:uwrite datatype="boolean">true</unix:uwrite>
    <unix:uexec  datatype="boolean">true</unix:uexec>
    <unix:gread  datatype="boolean">true</unix:gread>
    <unix:gwrite datatype="boolean">false</unix:gwrite>
    <unix:gexec  datatype="boolean">true</unix:gexec>
    <unix:oread  datatype="boolean">false</unix:oread>
    <unix:owrite datatype="boolean">false</unix:owrite>
    <unix:oexec  datatype="boolean">false</unix:oexec>
  </unix:file_state>

</def-group>
