<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_005200" version="2">
    <metadata>
      <title>MD7X-00-005200 - MongoDB must protect the confidentiality and integrity of all information at rest.</title>
      <description>Checks that MongoDB encryption-at-rest is enabled via the
      security.enableEncryption setting in mongod.conf. This requires MongoDB
      Enterprise and must be configured before the database is initialized.</description>
      <reference source="STIG" ref_id="MD7X-00-005200" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_005200_oval_mil_disa_stig_mongodb7_tst_encr"
                 comment="security.enableEncryption is true in mongod.conf" />
    </criteria>
  </definition>

  <ind:textfilecontent54_object
      id="mongodb_md7x_00_005200_oval_mil_disa_stig_mongodb7_obj_encr"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*enableEncryption\s*:\s*(true|yes)\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_005200_oval_mil_disa_stig_mongodb7_tst_encr"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="security.enableEncryption is configured as true">
    <ind:object object_ref="mongodb_md7x_00_005200_oval_mil_disa_stig_mongodb7_obj_encr" />
  </ind:textfilecontent54_test>

</def-group>
