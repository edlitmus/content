<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_003200" version="2">
    <metadata>
      <title>MD7X-00-003200 - Unused MongoDB components integrated into the database must be disabled.</title>
      <description>Checks that security.javascriptEnabled is false in mongod.conf. Disabling server-side JavaScript removes the V8 engine, an integrated but non-mandatory execution subsystem that increases attack surface when enabled.</description>
      <reference source="STIG" ref_id="MD7X-00-003200" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_003200_oval_mil_disa_stig_mongodb7_tst_15" comment="MD7X-00-003200 pattern 15 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_003200_oval_mil_disa_stig_mongodb7_obj_14" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*javascriptEnabled\s*:\s*false\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_003200_oval_mil_disa_stig_mongodb7_tst_15" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-003200 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_003200_oval_mil_disa_stig_mongodb7_obj_14" />
  </ind:textfilecontent54_test>
  </def-group>
