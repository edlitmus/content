<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_012400" version="2">
    <metadata>
      <title>MD7X-00-012400 - MongoDB must off-load audit data to a separate log management facility in near real time.</title>
      <description>Checks that systemLog.destination or auditLog.destination is set to
      syslog in mongod.conf. Syslog forwarding ensures continuous, near-real-time
      off-loading of audit records to a centralized log management facility, protecting
      against local storage exhaustion or tampering.</description>
      <reference source="STIG" ref_id="MD7X-00-012400" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_012400_syslog_dest_tst"
                 comment="destination is syslog in mongod.conf" />
    </criteria>
  </definition>

  <ind:textfilecontent54_object
      id="mongodb_md7x_00_012400_syslog_dest_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*destination\s*:\s*syslog\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_012400_syslog_dest_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="destination: syslog configured in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_012400_syslog_dest_obj" />
  </ind:textfilecontent54_test>

</def-group>
