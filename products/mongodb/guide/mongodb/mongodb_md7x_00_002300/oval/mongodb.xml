<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:unix="http://oval.mitre.org/XMLSchema/oval-definitions-5#unix">

  <definition class="compliance" id="mongodb_md7x_00_002300" version="2">
    <metadata>
      <title>MD7X-00-002300 - MongoDB must protect its audit features from unauthorized access.</title>
      <description>Checks that /etc/mongod.conf has mode 0640 or more restrictive
      (rw-r-----) and is owned by the mongod user. The mongod.conf file contains
      audit configuration including log destinations, filters, and format settings.
      Unprotected audit configuration can be tampered with to disable or redirect
      audit logging.</description>
      <reference source="STIG" ref_id="MD7X-00-002300" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_002300_oval_mil_disa_stig_mongodb7_conffile_tst"
                 comment="/etc/mongod.conf has mode 0640, not world-readable" />
    </criteria>
  </definition>

  <unix:file_test
      id="mongodb_md7x_00_002300_oval_mil_disa_stig_mongodb7_conffile_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="/etc/mongod.conf has mode 0640 (rw-r-----)">
    <unix:object object_ref="mongodb_md7x_00_002300_oval_mil_disa_stig_mongodb7_conffile_obj" />
    <unix:state  state_ref="mongodb_md7x_00_002300_oval_mil_disa_stig_mongodb7_conffile_state" />
  </unix:file_test>

  <unix:file_object
      id="mongodb_md7x_00_002300_oval_mil_disa_stig_mongodb7_conffile_obj"
      version="1">
    <unix:filepath>/etc/mongod.conf</unix:filepath>
  </unix:file_object>

  <!-- Mode 0640: owner=rw, group=r, other=none -->
  <unix:file_state
      id="mongodb_md7x_00_002300_oval_mil_disa_stig_mongodb7_conffile_state"
      version="1">
    <unix:uread  datatype="boolean">true</unix:uread>
    <unix:uwrite datatype="boolean">true</unix:uwrite>
    <unix:uexec  datatype="boolean">false</unix:uexec>
    <unix:gread  datatype="boolean">true</unix:gread>
    <unix:gwrite datatype="boolean">false</unix:gwrite>
    <unix:gexec  datatype="boolean">false</unix:gexec>
    <unix:oread  datatype="boolean">false</unix:oread>
    <unix:owrite datatype="boolean">false</unix:owrite>
    <unix:oexec  datatype="boolean">false</unix:oexec>
  </unix:file_state>

</def-group>
