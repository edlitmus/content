<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_006800" version="2">
    <metadata>
      <title>MD7X-00-006800 - MongoDB must prevent nonprivileged users from executing privileged functions.</title>
      <description>Checks that security.authorization is enabled in mongod.conf. With RBAC active, administrative operations (user management, server configuration, clusterAdmin actions) are restricted to principals assigned privileged roles. Nonprivileged users cannot execute these operations without explicit role grants.</description>
      <reference source="STIG" ref_id="MD7X-00-006800" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_006800_oval_mil_disa_stig_mongodb7_tst_23" comment="MD7X-00-006800 pattern 23 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_006800_oval_mil_disa_stig_mongodb7_obj_1" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*authorization\s*:\s*"?enabled"?\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_006800_oval_mil_disa_stig_mongodb7_tst_23" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-006800 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_006800_oval_mil_disa_stig_mongodb7_obj_1" />
  </ind:textfilecontent54_test>
  </def-group>
