<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_007400" version="2">
    <metadata>
      <title>MD7X-00-007400 - MongoDB must provide an immediate real-time alert to support staff of all audit log failures.</title>
      <description>Checks that systemLog.destination or auditLog.destination is set to
      syslog. Syslog forwarding ensures that audit log events (including failures such as
      dropped records) are immediately forwarded to a centralized monitoring infrastructure
      capable of generating real-time alerts.</description>
      <reference source="STIG" ref_id="MD7X-00-007400" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="OR">
      <criterion test_ref="mongodb_md7x_00_007400_syslog_dest_tst"
                 comment="systemLog.destination or auditLog.destination is syslog" />
    </criteria>
  </definition>

  <!-- Check: destination: syslog present in mongod.conf -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_007400_syslog_dest_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*destination\s*:\s*syslog\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_007400_syslog_dest_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="destination: syslog is configured in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_007400_syslog_dest_obj" />
  </ind:textfilecontent54_test>

</def-group>
