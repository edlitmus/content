<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_000400" version="1">
    <metadata>
      <title>MD7X-00-000400 - MongoDB must provide audit record generation for DOD-defined auditable events within all DBMS/database components.</title>
      <description>Standalone OVAL definition for MD7X-00-000400 using static mongod.conf pattern matching.</description>
      <reference source="STIG" ref_id="MD7X-00-000400" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_000400_oval_mil_disa_stig_mongodb7_tst_3" comment="MD7X-00-000400 pattern 3 matched" />
      <criterion test_ref="mongodb_md7x_00_000400_oval_mil_disa_stig_mongodb7_tst_4" comment="MD7X-00-000400 pattern 4 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_000400_oval_mil_disa_stig_mongodb7_obj_3" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*auditLog\s*:\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_object id="mongodb_md7x_00_000400_oval_mil_disa_stig_mongodb7_obj_4" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*auditAuthorizationSuccess\s*:\s*true\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_000400_oval_mil_disa_stig_mongodb7_tst_3" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-000400 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_000400_oval_mil_disa_stig_mongodb7_obj_3" />
  </ind:textfilecontent54_test>
  <ind:textfilecontent54_test id="mongodb_md7x_00_000400_oval_mil_disa_stig_mongodb7_tst_4" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-000400 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_000400_oval_mil_disa_stig_mongodb7_obj_4" />
  </ind:textfilecontent54_test>
  </def-group>
