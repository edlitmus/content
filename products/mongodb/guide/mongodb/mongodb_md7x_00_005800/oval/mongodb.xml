<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_005800" version="2">
    <metadata>
      <title>MD7X-00-005800 - MongoDB must reserve the use of dynamic code execution for situations that require it.</title>
      <description>Checks that security.javascriptEnabled is false in mongod.conf. Server-side JavaScript execution (mapReduce, $where, $function) allows arbitrary code evaluation and must be disabled unless a specific audited use case requires it.</description>
      <reference source="STIG" ref_id="MD7X-00-005800" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_005800_oval_mil_disa_stig_mongodb7_tst_18" comment="MD7X-00-005800 pattern 18 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_005800_oval_mil_disa_stig_mongodb7_obj_14" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*javascriptEnabled\s*:\s*false\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_005800_oval_mil_disa_stig_mongodb7_tst_18" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-005800 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_005800_oval_mil_disa_stig_mongodb7_obj_14" />
  </ind:textfilecontent54_test>
  </def-group>
