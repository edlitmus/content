<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_007300" version="2">
    <metadata>
      <title>MD7X-00-007300 - MongoDB must provide a warning when audit record storage reaches 75 percent of capacity.</title>
      <description>Checks that (1) the auditLog section is present and (2) log rotation
      is configured via systemLog.logRotate, which enables proactive audit storage
      management. The 75% capacity alert is implemented at the OS/monitoring layer
      feeding this log destination; this OVAL verifies the prerequisite configuration.</description>
      <reference source="STIG" ref_id="MD7X-00-007300" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_007300_auditlog_tst"
                 comment="auditLog section present in mongod.conf" />
      <criterion test_ref="mongodb_md7x_00_007300_logrotate_tst"
                 comment="systemLog.logRotate is configured" />
    </criteria>
  </definition>

  <!-- Check 1: auditLog section present -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_007300_auditlog_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*auditLog\s*:\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_007300_auditlog_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="auditLog: section present in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_007300_auditlog_obj" />
  </ind:textfilecontent54_test>

  <!-- Check 2: logRotate is configured -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_007300_logrotate_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*logRotate\s*:\s*(rename|reopen)\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_007300_logrotate_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="systemLog.logRotate is set to rename or reopen in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_007300_logrotate_obj" />
  </ind:textfilecontent54_test>

</def-group>
