<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_004400" version="2">
    <metadata>
      <title>MD7X-00-004400 - MongoDB must use NIST FIPS 140-2 or 140-3 validated cryptographic modules.</title>
      <description>Checks that security.FIPSMode is true in mongod.conf. Setting FIPSMode forces MongoDB to use the system OpenSSL library in FIPS mode, restricting cryptographic operations to FIPS 140-2 or 140-3 validated algorithms only.</description>
      <reference source="STIG" ref_id="MD7X-00-004400" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_004400_oval_mil_disa_stig_mongodb7_tst_11" comment="MD7X-00-004400 pattern 11 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_004400_oval_mil_disa_stig_mongodb7_obj_11" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*FIPSMode\s*:\s*true\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_004400_oval_mil_disa_stig_mongodb7_tst_11" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-004400 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_004400_oval_mil_disa_stig_mongodb7_obj_11" />
  </ind:textfilecontent54_test>
  </def-group>
