<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_002900" version="2">
    <metadata>
      <title>MD7X-00-002900 - Database objects must be owned by database principals authorized for ownership.</title>
      <description>Checks that security.authorization is enabled in mongod.conf. MongoDB enforces object ownership through its RBAC model -- only principals with the dbOwner or equivalent role can modify owned collections. Authorization must be enabled for ownership controls to be active.</description>
      <reference source="STIG" ref_id="MD7X-00-002900" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_002900_oval_mil_disa_stig_mongodb7_tst_30" comment="MD7X-00-002900 pattern 30 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_002900_oval_mil_disa_stig_mongodb7_obj_1" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*authorization\s*:\s*"?enabled"?\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_002900_oval_mil_disa_stig_mongodb7_tst_30" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-002900 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_002900_oval_mil_disa_stig_mongodb7_obj_1" />
  </ind:textfilecontent54_test>
  </def-group>
