<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_008000" version="2">
    <metadata>
      <title>MD7X-00-008000 - The DBMS must disable network functions, ports, protocols, and services deemed nonsecure.</title>
      <description>Checks that net.tls.mode is set to requireTLS in mongod.conf.
      Setting requireTLS disables plaintext (cleartext) MongoDB wire protocol
      connections on all configured listeners, ensuring only TLS-encrypted
      connections are accepted in accordance with PPSM guidance.</description>
      <reference source="STIG" ref_id="MD7X-00-008000" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_008000_oval_mil_disa_stig_mongodb7_tst_tls"
                 comment="net.tls.mode is requireTLS, disabling plaintext connections" />
    </criteria>
  </definition>

  <ind:textfilecontent54_object
      id="mongodb_md7x_00_008000_oval_mil_disa_stig_mongodb7_obj_tls"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*mode\s*:\s*requireTLS\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_008000_oval_mil_disa_stig_mongodb7_tst_tls"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="net.tls.mode is requireTLS">
    <ind:object object_ref="mongodb_md7x_00_008000_oval_mil_disa_stig_mongodb7_obj_tls" />
  </ind:textfilecontent54_test>

</def-group>
