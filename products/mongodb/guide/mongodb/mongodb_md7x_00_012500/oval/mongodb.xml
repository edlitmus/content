<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_012500" version="2">
    <metadata>
      <title>MD7X-00-012500 - MongoDB must be configured per DOD security configuration and implementation guidance.</title>
      <description>Checks three core DoD baseline controls: (1) security.authorization
      is enabled, (2) net.tls.mode is requireTLS enforcing encrypted connections,
      and (3) the auditLog section is present enabling audit logging. These collectively
      represent the minimum DoD STIG configuration baseline.</description>
      <reference source="STIG" ref_id="MD7X-00-012500" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_012500_auth_tst"
                 comment="security.authorization is enabled" />
      <criterion test_ref="mongodb_md7x_00_012500_tls_tst"
                 comment="net.tls.mode is requireTLS" />
      <criterion test_ref="mongodb_md7x_00_012500_auditlog_tst"
                 comment="auditLog section is present" />
    </criteria>
  </definition>

  <!-- Check 1: authorization: enabled -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_012500_auth_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*authorization\s*:\s*"?enabled"?\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_012500_auth_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="authorization: enabled present in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_012500_auth_obj" />
  </ind:textfilecontent54_test>

  <!-- Check 2: net.tls.mode: requireTLS -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_012500_tls_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*mode\s*:\s*requireTLS\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_012500_tls_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="net.tls.mode: requireTLS present in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_012500_tls_obj" />
  </ind:textfilecontent54_test>

  <!-- Check 3: auditLog section present -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_012500_auditlog_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*auditLog\s*:\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_012500_auditlog_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="auditLog: section header present in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_012500_auditlog_obj" />
  </ind:textfilecontent54_test>

</def-group>
