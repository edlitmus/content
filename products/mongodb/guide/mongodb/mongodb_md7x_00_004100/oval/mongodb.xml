<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"
           xmlns:unix="http://oval.mitre.org/XMLSchema/oval-definitions-5#unix">

  <definition class="compliance" id="mongodb_md7x_00_004100" version="2">
    <metadata>
      <title>MD7X-00-004100 - MongoDB must enforce authorized access to all PKI private keys stored/used by MongoDB.</title>
      <description>Checks that (1) net.tls.PEMKeyFile is configured in mongod.conf,
      and (2) the referenced PEM key file has mode 0600 (rw-------), ensuring
      only the owning process account can read the private key material.</description>
      <reference source="STIG" ref_id="MD7X-00-004100" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_conf_tst"
                 comment="net.tls.PEMKeyFile is configured in mongod.conf" />
      <criterion test_ref="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_keyfile_tst"
                 comment="TLS PEM key file has restricted permissions (mode 0600)" />
    </criteria>
  </definition>

  <!-- Step 1: Verify PEMKeyFile is configured and capture the path -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_conf_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*PEMKeyFile\s*:\s*(\S+)\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_conf_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="PEMKeyFile is configured in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_conf_obj" />
  </ind:textfilecontent54_test>

  <!-- Variable: extracted PEM key file path from mongod.conf -->
  <local_variable
      id="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_keyfile_var"
      datatype="string" version="1"
      comment="PEM key file path extracted from net.tls.PEMKeyFile in mongod.conf">
    <object_component
        object_ref="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_conf_obj"
        item_field="subexpression" />
  </local_variable>

  <!-- Step 2: Verify the key file has mode 0600 (owner read-write only) -->
  <unix:file_object
      id="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_keyfile_obj"
      version="1">
    <unix:filepath
        var_ref="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_keyfile_var"
        var_check="at least one" />
  </unix:file_object>

  <unix:file_state
      id="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_keyfile_state"
      version="1">
    <unix:uread  datatype="boolean">true</unix:uread>
    <unix:uwrite datatype="boolean">true</unix:uwrite>
    <unix:uexec  datatype="boolean">false</unix:uexec>
    <unix:gread  datatype="boolean">false</unix:gread>
    <unix:gwrite datatype="boolean">false</unix:gwrite>
    <unix:gexec  datatype="boolean">false</unix:gexec>
    <unix:oread  datatype="boolean">false</unix:oread>
    <unix:owrite datatype="boolean">false</unix:owrite>
    <unix:oexec  datatype="boolean">false</unix:oexec>
  </unix:file_state>

  <unix:file_test
      id="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_keyfile_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="TLS PEM key file has mode 0600 (rw-------)">
    <unix:object object_ref="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_keyfile_obj" />
    <unix:state  state_ref="mongodb_md7x_00_004100_oval_mil_disa_stig_mongodb7_keyfile_state" />
  </unix:file_test>

</def-group>
