<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_004600" version="2">
    <metadata>
      <title>MD7X-00-004600 - MongoDB must separate user functionality from database management functionality.</title>
      <description>Checks that security.authorization is enabled in mongod.conf. Enabling RBAC ensures that end-user roles (read, readWrite) are separate from administrative roles (dbAdmin, clusterAdmin, root), providing functional separation between regular users and database management principals.</description>
      <reference source="STIG" ref_id="MD7X-00-004600" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_004600_oval_mil_disa_stig_mongodb7_tst_34" comment="MD7X-00-004600 pattern 34 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_004600_oval_mil_disa_stig_mongodb7_obj_1" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*authorization\s*:\s*"?enabled"?\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_004600_oval_mil_disa_stig_mongodb7_tst_34" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-004600 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_004600_oval_mil_disa_stig_mongodb7_obj_1" />
  </ind:textfilecontent54_test>
  </def-group>
