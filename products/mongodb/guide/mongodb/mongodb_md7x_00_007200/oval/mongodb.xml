<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_007200" version="2">
    <metadata>
      <title>MD7X-00-007200 - MongoDB must allocate audit record storage capacity in accordance with site requirements.</title>
      <description>Checks that (1) the auditLog section is present in mongod.conf,
      and (2) an explicit audit log file path is configured, demonstrating that
      audit record storage capacity has been planned and allocated.</description>
      <reference source="STIG" ref_id="MD7X-00-007200" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_007200_auditlog_section_tst"
                 comment="auditLog section present in mongod.conf" />
      <criterion test_ref="mongodb_md7x_00_007200_auditlog_path_tst"
                 comment="auditLog.path explicitly configured" />
    </criteria>
  </definition>

  <!-- Check 1: auditLog section header present -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_007200_auditlog_section_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*auditLog\s*:\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_007200_auditlog_section_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="auditLog: section header present in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_007200_auditlog_section_obj" />
  </ind:textfilecontent54_test>

  <!-- Check 2: path is configured (log file destination set) -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_007200_auditlog_path_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*path\s*:\s*/\S+\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_007200_auditlog_path_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="auditLog.path configured with an absolute path">
    <ind:object object_ref="mongodb_md7x_00_007200_auditlog_path_obj" />
  </ind:textfilecontent54_test>

</def-group>
