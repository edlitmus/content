<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_009000" version="2">
    <metadata>
      <title>MD7X-00-009000 - MongoDB must behave predictably when invalid inputs are received.</title>
      <description>Checks that security.javascriptEnabled is set to false in mongod.conf.
      Disabling server-side JavaScript removes the V8 engine execution path, eliminating
      a class of invalid-input vulnerabilities where malicious JS expressions could be
      evaluated server-side, causing unpredictable or unsafe behavior.</description>
      <reference source="STIG" ref_id="MD7X-00-009000" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_009000_js_disabled_tst"
                 comment="security.javascriptEnabled is false" />
    </criteria>
  </definition>

  <ind:textfilecontent54_object
      id="mongodb_md7x_00_009000_js_disabled_obj"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*javascriptEnabled\s*:\s*false\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_009000_js_disabled_tst"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="security.javascriptEnabled: false present in mongod.conf">
    <ind:object object_ref="mongodb_md7x_00_009000_js_disabled_obj" />
  </ind:textfilecontent54_test>

</def-group>
