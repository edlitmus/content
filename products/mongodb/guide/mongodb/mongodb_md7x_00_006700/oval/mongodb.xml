<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_006700" version="2">
    <metadata>
      <title>MD7X-00-006700 - MongoDB must enforce discretionary access control (DAC) policies as defined by the data owner.</title>
      <description>Checks that security.authorization is enabled in mongod.conf. MongoDB implements DAC through its RBAC model where collection owners (dbOwner role) can grant or revoke access to other principals. Authorization must be enabled for these discretionary controls to be enforced.</description>
      <reference source="STIG" ref_id="MD7X-00-006700" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_006700_oval_mil_disa_stig_mongodb7_tst_13" comment="MD7X-00-006700 pattern 13 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_006700_oval_mil_disa_stig_mongodb7_obj_13" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*authorization\s*:\s*"?enabled"?\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_006700_oval_mil_disa_stig_mongodb7_tst_13" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-006700 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_006700_oval_mil_disa_stig_mongodb7_obj_13" />
  </ind:textfilecontent54_test>
  </def-group>
