<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_003800" version="1">
    <metadata>
      <title>MD7X-00-003800 - If passwords are used for authentication, MongoDB must store only hashed, salted representations of passwords.</title>
      <description>Standalone OVAL definition for MD7X-00-003800 using static mongod.conf pattern matching.</description>
      <reference source="STIG" ref_id="MD7X-00-003800" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_003800_oval_mil_disa_stig_mongodb7_tst_5" comment="MD7X-00-003800 pattern 5 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_003800_oval_mil_disa_stig_mongodb7_obj_5" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*authenticationMechanisms\s*:\s*"?.*(SCRAM-SHA-256|SCRAM-SHA-512).*"?\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_003800_oval_mil_disa_stig_mongodb7_tst_5" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-003800 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_003800_oval_mil_disa_stig_mongodb7_obj_5" />
  </ind:textfilecontent54_test>
  </def-group>
