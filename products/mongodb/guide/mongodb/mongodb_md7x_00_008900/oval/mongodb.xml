<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5"
           xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent">

  <definition class="compliance" id="mongodb_md7x_00_008900" version="2">
    <metadata>
      <title>MD7X-00-008900 - MongoDB must maintain the confidentiality and integrity of information during reception.</title>
      <description>Checks that (1) net.tls.mode is requireTLS and (2)
      net.tls.allowInvalidCertificates is false in mongod.conf. Reception of
      data over the network uses the same TLS configuration as transmission;
      requireTLS ensures received data is from authenticated, encrypted channels.</description>
      <reference source="STIG" ref_id="MD7X-00-008900" />
      <affected family="unix"><platform>MongoDB</platform></affected>
    </metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_008900_oval_mil_disa_stig_mongodb7_tst_tls"
                 comment="net.tls.mode is requireTLS in mongod.conf" />
      <criterion test_ref="mongodb_md7x_00_008900_oval_mil_disa_stig_mongodb7_tst_certval"
                 comment="net.tls.allowInvalidCertificates is false" />
    </criteria>
  </definition>

  <!-- Check net.tls.mode: requireTLS -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_008900_oval_mil_disa_stig_mongodb7_obj_tls"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*mode\s*:\s*requireTLS\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_008900_oval_mil_disa_stig_mongodb7_tst_tls"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="net.tls.mode is requireTLS">
    <ind:object object_ref="mongodb_md7x_00_008900_oval_mil_disa_stig_mongodb7_obj_tls" />
  </ind:textfilecontent54_test>

  <!-- Check net.tls.allowInvalidCertificates: false -->
  <ind:textfilecontent54_object
      id="mongodb_md7x_00_008900_oval_mil_disa_stig_mongodb7_obj_certval"
      version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*allowInvalidCertificates\s*:\s*(false|no)\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test
      id="mongodb_md7x_00_008900_oval_mil_disa_stig_mongodb7_tst_certval"
      version="1" check="all" check_existence="at_least_one_exists"
      comment="net.tls.allowInvalidCertificates is false">
    <ind:object object_ref="mongodb_md7x_00_008900_oval_mil_disa_stig_mongodb7_obj_certval" />
  </ind:textfilecontent54_test>

</def-group>
