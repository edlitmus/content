<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_006100" version="2">
    <metadata>
      <title>MD7X-00-006100 - MongoDB must reveal detailed error messages only to authorized personnel.</title>
      <description>Checks that security.redactClientLogData is true in mongod.conf. When log data is redacted, verbose diagnostic information containing document contents is suppressed, limiting detailed operational data to authorized system administrators only.</description>
      <reference source="STIG" ref_id="MD7X-00-006100" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_006100_oval_mil_disa_stig_mongodb7_tst_17" comment="MD7X-00-006100 pattern 17 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_006100_oval_mil_disa_stig_mongodb7_obj_12" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*redactClientLogData\s*:\s*true\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_006100_oval_mil_disa_stig_mongodb7_tst_17" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-006100 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_006100_oval_mil_disa_stig_mongodb7_obj_12" />
  </ind:textfilecontent54_test>
  </def-group>
