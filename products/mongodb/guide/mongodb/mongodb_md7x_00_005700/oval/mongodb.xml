<def-group xmlns="http://oval.mitre.org/XMLSchema/oval-definitions-5" xmlns:ind="http://oval.mitre.org/XMLSchema/oval-definitions-5#independent"><definition class="compliance" id="mongodb_md7x_00_005700" version="2">
    <metadata>
      <title>MD7X-00-005700 - MongoDB must check the validity of all data inputs except those explicitly identified as exempt.</title>
      <description>Checks that security.javascriptEnabled is false in mongod.conf. Disabling server-side JavaScript prevents malicious or unexpected code from executing in the query pipeline, reducing the risk of adverse behavior from invalid or specially crafted inputs.</description>
      <reference source="STIG" ref_id="MD7X-00-005700" />
    <affected family="unix"><platform>MongoDB</platform></affected></metadata>
    <criteria operator="AND">
      <criterion test_ref="mongodb_md7x_00_005700_oval_mil_disa_stig_mongodb7_tst_22" comment="MD7X-00-005700 pattern 22 matched" />
    </criteria>
  </definition>
  <ind:textfilecontent54_object id="mongodb_md7x_00_005700_oval_mil_disa_stig_mongodb7_obj_14" version="1">
    <ind:filepath>/etc/mongod.conf</ind:filepath>
    <ind:pattern operation="pattern match">^\s*javascriptEnabled\s*:\s*false\s*$</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
  <ind:textfilecontent54_test id="mongodb_md7x_00_005700_oval_mil_disa_stig_mongodb7_tst_22" version="1" check="all" check_existence="at_least_one_exists" comment="MD7X-00-005700 config pattern present">
    <ind:object object_ref="mongodb_md7x_00_005700_oval_mil_disa_stig_mongodb7_obj_14" />
  </ind:textfilecontent54_test>
  </def-group>
